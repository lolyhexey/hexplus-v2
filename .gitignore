# Build artifacts
/dist/
/build/cache/
/build/out/
# Anchored to repo root: ignore the produced binary, not the cmd/hexplus/ source dir
/hexplus
/hexplus-*
*.exe

# Bundled binaries (built separately by build/build-statics.sh, then
# copied into internal/assets/bin/ before the final go build). Ignore
# everything under that dir except the markers we ship to keep embed.FS
# walking on a fresh checkout.
/internal/assets/bin/*
!/internal/assets/bin/.gitkeep
!/internal/assets/bin/README.placeholder
!/internal/assets/bin/mime.conf

# Local dev
.idea/
.vscode/
.DS_Store
*.swp

# Test outputs
/tmp/
*.log
